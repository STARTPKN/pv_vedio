generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  videos    Video[]
  createdAt DateTime @default(now())
}

model Video {
  id           Int      @id @default(autoincrement())
  title        String
  videoUrl     String
  thumbnailUrl String?
  cloudinaryId String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}
